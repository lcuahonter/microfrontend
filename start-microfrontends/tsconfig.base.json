{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "esnext",
    "useDefineForClassFields": false,
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@libs/*": ["libs/*"],
      "@ng-mf/data-access-user": ["libs/shared/data-access-user/src/index.ts"],
      "@package-json": ["package.json"],
      "aga/Routes": ["apps/aga/src/app/remote-entry/entry.routes.ts"],
      "agace/Routes": ["apps/agace/src/app/remote-entry/entry.routes.ts"],
      "agricultura/Routes": [
        "apps/agricultura/src/app/remote-entry/entry.routes.ts"
      ],
      "bandejas/Routes": ["apps/bandejas/src/app/remote-entry/entry.routes.ts"],
      "cofepris/Routes": ["apps/cofepris/src/app/remote-entry/entry.routes.ts"],
      "crt/Routes": ["apps/crt/src/app/remote-entry/entry.routes.ts"],
      "ferroviarios/Routes": [
        "apps/ferroviarios/src/app/remote-entry/entry.routes.ts"
      ],
      "funcionario/Routes": [
        "apps/funcionario/src/app/remote-entry/entry.routes.ts"
      ],
      "inah/Routes": ["apps/inah/src/app/remote-entry/entry.routes.ts"],
      "inbal/Routes": ["apps/inbal/src/app/remote-entry/entry.routes.ts"],
      "login/Routes": ["apps/login/src/app/remote-entry/entry.routes.ts"],
      "manifestacionvalor/Routes": [
        "apps/manifestacionvalor/src/app/remote-entry/entry.routes.ts"
      ],
      "maritimos/Routes": [
        "apps/maritimos/src/app/remote-entry/entry.routes.ts"
      ],
      "privados/Routes": ["apps/privados/src/app/remote-entry/entry.routes.ts"],
      "profepa/Routes": ["apps/profepa/src/app/remote-entry/entry.routes.ts"],
      "se/Routes": ["apps/se/src/app/remote-entry/entry.routes.ts"],
      "semarnat/Routes": ["apps/semarnat/src/app/remote-entry/entry.routes.ts"],
      "sener/Routes": ["apps/sener/src/app/remote-entry/entry.routes.ts"],
      "stps/Routes": ["apps/stps/src/app/remote-entry/entry.routes.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
