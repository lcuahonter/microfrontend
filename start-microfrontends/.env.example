# Variables de entorno para VUCEM Microfrontends

# Entorno (development, staging, production)
NODE_ENV=development

# URLs del API Backend para diferentes entornos
API_URL_DEV=https://api-dev.vucem.example.com
API_URL_STAGING=https://api-staging.vucem.example.com
API_URL_PROD=https://api.vucem.example.com

# Configuración de Registry de Docker
DOCKER_REGISTRY=ghcr.io
DOCKER_BASE_IMAGE_NAME=vucem-front

# Configuración de Kubernetes
K8S_NAMESPACE_DEV=vucem-dev
K8S_NAMESPACE_STAGING=vucem-staging
K8S_NAMESPACE_PROD=vucem-prod

# Configuración de recursos para Kubernetes
K8S_MIN_REPLICAS_DEV=1
K8S_MAX_REPLICAS_DEV=2
K8S_MIN_REPLICAS_STAGING=1
K8S_MAX_REPLICAS_STAGING=3
K8S_MIN_REPLICAS_PROD=2
K8S_MAX_REPLICAS_PROD=5

# Versiones para el desarrollo
NODE_VERSION=22.14.0
NX_VERSION=19.3.1