{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": [],
    "target": "ES2020",
    "paths": {
      "@/*": ["apps/privados/src/app/*"],
      "@app/*": ["apps/privados/src/app/*"],
      "@shared/*": ["apps/privados/src/app/shared/*"],
      "@core/*": ["apps/privados/src/app/core/*"]
    }
  },
  "files": [
    "src/main.ts",
    "src/bootstrap.ts",
    "src/app/remote-entry/entry.routes.ts",
    "src/custom.d.ts"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ]
}
