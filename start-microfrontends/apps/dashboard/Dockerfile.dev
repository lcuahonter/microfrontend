# Dockerfile for building and serving the Angular dashboard application.

# ------------------------------
# Stage 1: Build the Angular app
# ------------------------------
FROM node:22-slim AS node
WORKDIR /app

# --- Copy dependency configuration files first --- 
COPY *.json ./

# --- Install dependencies ---
# Install pnpm globally, configure its global binary directory,
# install Nx CLI, install project dependencies and add webpack.
RUN npm install -g pnpm && \
    mkdir -p /pnpm-global && \
    pnpm config set prefix "/pnpm-global/bin" && \
    export PNPM_HOME=/pnpm-global/bin && \
    export PATH=$PNPM_HOME:$PATH && \
    pnpm add -g nx && \
    pnpm install --no-lockfile && \
    pnpm add webpack@5.91.0

# --- Copy the application source code ---
COPY apps ./apps
COPY libs ./libs
# Optional: Check directory structure (currently disabled)
# RUN pwd && ls -a /app

# Optional: Reset Nx cache (disabled)
# RUN npx nx reset

# Enable verbose logging for Nx.
ENV NX_VERBOSE_LOGGING=true
# Optional: Enable Nx daemon (disabled)
# ENV NX_DEAMON=true

ARG NODE_ENV
RUN echo "Building dashboard image for environment: $NODE_ENV"
# Build the dashboard application using Nx.
ENV NODE_OPTIONS=--max-old-space-size=10096
RUN npx nx build dashboard --configuration=$NODE_ENV --skip-nx-cache --verbose
# Optional: Verify build output (disabled)
# RUN pwd && ls -a /app/dist/apps/dashboard

# ------------------------------
# Stage 2: Serve with Nginx
# ------------------------------
FROM nginx:alpine-slim
# Copy custom Nginx configuration for the dashboard.
COPY ./apps/dashboard/nginx.conf /etc/nginx/nginx.conf
# Copy the built dashboard application from Stage 1 to the Nginx-served directory.
COPY --from=node app/dist/apps/dashboard /usr/share/nginx/html