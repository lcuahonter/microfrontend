# Dockerfile for building and serving the Angular profepa application.

# ------------------------------
# Stage 1: Build the Angular app
# ------------------------------
FROM node:22-slim AS node
WORKDIR /app

# --- Copy dependency configuration files first ---
COPY *.json ./

# --- Copy scripts directory (needed for postinstall/versioning) ---
COPY script ./script

# --- Install dependencies ---
RUN npm install -g pnpm && \
    mkdir -p /pnpm-global && \
    pnpm config set prefix "/pnpm-global/bin" && \
    export PNPM_HOME=/pnpm-global/bin && \
    export PATH=$PNPM_HOME:$PATH && \
    pnpm add -g nx && \
    pnpm install --no-lockfile && \
    pnpm add webpack@5.91.0

# --- Copy the application source code ---
COPY apps ./apps
COPY libs ./libs
COPY apps/profepa/src ./src

# Enable verbose logging for Nx.
ENV NX_VERBOSE_LOGGING=true

ARG NODE_ENV
RUN echo "Building profepa image for environment: $NODE_ENV"
ENV NODE_OPTIONS=--max-old-space-size=10096
RUN npx nx build profepa --configuration=$NODE_ENV --base-href=/profepa/ --skip-nx-cache --verbose

# --- Inject version into built index.html ---
RUN node script/inject-version.js profepa

# ------------------------------
# Stage 2: Serve with Nginx
# ------------------------------
FROM nginx:alpine-slim
# Copy custom Nginx configuration for the profepa.
COPY ./apps/profepa/nginx.conf /etc/nginx/nginx.conf
# Copy the built profepa application from Stage 1 to the Nginx-served directory.
COPY --from=node /app/dist/apps/profepa /usr/share/nginx/html
